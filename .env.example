# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ---- Required --------------------------------------------------------
DISCORD_TOKEN=your_bot_token_here

# ---- Sync mode -------------------------------------------------------
# Use 'guild' locally so commands appear instantly in your test server.
# Use 'global' on the cloud host so commands work across all servers.
COMMAND_SYNC_MODE=guild

# Required only when COMMAND_SYNC_MODE=guild.
# Right-click your server name in Discord → Copy Server ID.
DISCORD_GUILD_ID=your_test_server_id_here
